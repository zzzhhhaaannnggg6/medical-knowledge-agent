# Host path to local textbook PDFs. Change this before running Docker Compose.
# Examples:
# TEXTBOOK_DIR=/Users/li/Desktop/黑客松/textbooks
# TEXTBOOK_DIR=C:\Users\you\Desktop\textbooks
# TEXTBOOK_DIR=./textbooks
TEXTBOOK_DIR=./textbooks

# Browser-facing FastAPI base URL used by the Vite frontend.
VITE_API_BASE=http://localhost:8001

# RAG pipeline tuning (matches hackathon spec 500–800 / 50–100).
RAG_CHUNK_SIZE=650
RAG_CHUNK_OVERLAP=80
RAG_TOP_K=5

# Embedding backend: "local" (default, pure-Python BM25 + TF-IDF) or
# "sentence_transformers" to opt into multilingual embeddings.
EMBEDDING_BACKEND=local
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Optional OpenAI-compatible LLM used for RAG answer generation.
# Leave LLM_API_KEY empty to run the extractive fallback (no outbound call).
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
